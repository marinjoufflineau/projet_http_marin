</main>

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <p>
        <%= (typeof footerText !== "undefined" && footerText)
          ? footerText
          : "Serveur Express + EJS — TP WebServer" %>
      </p>

      <% if (typeof footerLinks !== "undefined" && footerLinks && footerLinks.length) { %>
        <nav class="footer-nav" aria-label="Liens de pied de page">
          <% footerLinks.forEach(link => { %>
            <a href="<%= link.href %>"><%= link.label %></a>
          <% }) %>
        </nav>
      <% } %>
    </div>

    <div class="footer-right">
      <% if (typeof footerExtra !== "undefined" && footerExtra) { %>
        <p><%= footerExtra %></p>
      <% } %>

      <small>
        <% if (login) { %>
          Connecté : <strong><%= login %></strong> —
        <% } %>
        Mode admin : <strong><%= isAdmin ? "oui" : "non" %></strong>
      </small>
    </div>
  </div>
</footer>

</body>
</html>