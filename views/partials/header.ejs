<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles.css" />
</head>

<body class="<%= isAdmin ? 'admin' : '' %>">
<header class="site-header">
  <div class="container nav">
    <div class="brand">
      <a class="brand-link" href="/">
        <span class="brand-dot"></span>
        <strong>Projet HTTP</strong>
      </a>

      <% if (login) { %>
        <span class="badge">Bienvenue <%= login %></span>
      <% } %>
    </div>

    <nav class="nav-links" aria-label="Navigation principale">
      <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Accueil</a>
      <a class="<%= currentPath === '/about' ? 'active' : '' %>" href="/about">À propos</a>
      <a class="<%= currentPath === '/contact' ? 'active' : '' %>" href="/contact">Contact</a>
      <a class="<%= currentPath.startsWith('/dab') ? 'active' : '' %>" href="/dab">DAB</a>
      <a class="<%= currentPath === '/error' ? 'active' : '' %>" href="/error">Erreur</a>

      <% if (!login) { %>
        <a class="<%= currentPath === '/login' ? 'active' : '' %>" href="/login">Connexion</a>
      <% } else { %>
        <form method="POST" action="/logout" class="inline-form">
          <button type="submit">Déconnexion</button>
        </form>
      <% } %>
    </nav>
  </div>
</header>

<main class="container">