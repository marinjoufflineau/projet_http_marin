<%- include('partials/header', { title }) %>

<section class="card">
  <h1>Distributeur de billets</h1>

  <form method="POST" action="/dab" style="margin-top:12px;">
    <label for="amount">Montant (€)</label>
    <input id="amount" name="amount" type="number" min="0" step="0.01"
       placeholder="Ex: 137.45" required />


    <div style="margin-top:12px;">
      <button type="submit">Calculer</button>
    </div>
  </form>

  <% if (result) { %>
    <hr style="margin:18px 0; border:none; border-top:1px solid rgba(0,0,0,.12);" />

    <p>Montant demandé : <strong><%= amount %></strong></p>

    <% if (!result.ok) { %>
      <p class="error"><strong><%= result.error %></strong></p>
    <% } else { %>
      <p>Nombre minimal de coupures : <strong><%= result.billsCount %></strong></p>

      <ul>
        <% result.breakdown.forEach(x => { %>
          <% if (x.type === "€") { %>
            <li><strong><%= x.count %></strong> × <%= x.value %> €</li>
          <% } else { %>
            <li><strong><%= x.count %></strong> × <%= x.value %> centimes</li>
          <% } %>
        <% }) %>
      </ul>      
    <% } %>
  <% } %>
</section>

<%- include('partials/footer', { footerText: "Simulation du DAB" }) %>
